# AI Provider API Keys (required for AI features)
# Get your NVIDIA NIM API key from: https://build.nvidia.com/
NVIDIA_NIM_API_KEY=

# Get your OpenAI API key from: https://platform.openai.com/
OPENAI_API_KEY=

# Get your Anthropic API key from: https://www.anthropic.com/
ANTHROPIC_API_KEY=

# Get your OpenRouter API key from: https://openrouter.ai/
OPENROUTER_API_KEY=

# Optional: ElevenLabs for voice narration
ELEVENLABS_API_KEY=

# Database (auto-set by Vercel Postgres in production)
POSTGRES_URL=

# Auth (NextAuth.js v5)
NEXTAUTH_URL=http://localhost:4000
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
