{
  "version": 2,
  "builds": [
    {
      "src": "frontend/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ],
  "env": {
    "SECRET_KEY": "your-secret-key-for-production-change-this",
    "ALGORITHM": "HS256",
    "DATABASE_URL": "postgresql://vercel:password@localhost:5432/python_learner"
  }
}